{
  "name": "radius-website",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:3001": "next dev -p 3001",
    "clean": "rm -rf .next out",
    "build": "npm run clean && next build",
    "start": "serve out -l 3000 --no-port-switching",
    "start:3001": "serve out -l 3001 --no-port-switching",
    "deploy": "npm run build && gh-pages -d out"
  },
  "dependencies": {
    "gh-pages": "^6.3.0",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "eslint": "8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "8.4.38",
    "serve": "^14.2.6",
    "tailwindcss": "3.4.6",
    "typescript": "5.5.4"
  }
}
